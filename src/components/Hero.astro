---
// Hero — leads with Daniel as the person/builder, not the product
---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden px-5 pt-20">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--color-brand-primary)_0%,_transparent_50%)] opacity-15"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,_var(--color-brand-accent)_0%,_transparent_40%)] opacity-10"></div>

  <!-- Dot grid pattern -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 32px 32px;"></div>

  <div class="relative z-10 mx-auto max-w-3xl text-center">
    <!-- Badge -->
    <div class="mb-6 inline-block rounded-full border border-border-subtle bg-bg-card px-4 py-1.5 text-sm text-text-secondary backdrop-blur-sm">
      Developer &middot; Consultant &middot; Builder
    </div>

    <h1 class="text-4xl font-bold leading-tight tracking-tight md:text-5xl lg:text-6xl">
      <span id="hero-typed" aria-label="We Build Technology"></span><span id="hero-cursor" style="display:inline-block;width:2.5px;height:0.9em;background:#f0f0f5;vertical-align:middle;margin-left:3px;border-radius:1px;opacity:0;animation:hero-blink 0.7s step-end infinite;"></span><br />
      <span id="hero-sub-line" class="bg-linear-to-r from-brand-primary to-brand-accent bg-clip-text text-transparent" style="opacity:0;transition:opacity 1s ease 0.2s;">
        for Small Businesses.
      </span>
    </h1>

    <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-text-secondary md:text-xl">
      Available now for tech consulting, web design, and custom software —
      serving small businesses in Tampa, FL and remotely.
      Also building <strong class="font-semibold text-text-primary">Trackt</strong> — real-time inventory
      tracking and sales analytics for small business owners, launching soon.
    </p>

    <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
      <!-- Primary CTA: consulting -->
      <a
        href="/#consulting"
        class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-brand-primary px-8 py-4 text-lg font-semibold text-white transition-all hover:brightness-110 hover:shadow-[0_0_30px_var(--color-brand-glow)] sm:w-auto"
      >
        Let's Work Together
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>

      <!-- Secondary CTA: Trackt waitlist -->
      <a
        href="#waitlist"
        class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-brand-primary/50 px-8 py-4 text-lg font-semibold text-brand-primary transition-all hover:bg-brand-primary/10 sm:w-auto"
      >
        Follow Trackt
      </a>
    </div>
  </div>
</section>

<style>
  @keyframes hero-blink {
    0%, 100% { opacity: 0.8; }
    50%       { opacity: 0; }
  }
</style>

<script>
  (function () {
    var typed   = document.getElementById('hero-typed') as HTMLElement | null;
    var cursor  = document.getElementById('hero-cursor') as HTMLElement | null;
    var subLine = document.getElementById('hero-sub-line') as HTMLElement | null;
    if (!typed || !cursor || !subLine) return;

    var text = 'We Build Technology';
    var i = 0;

    function startTyping() {
      cursor!.style.opacity = '1';
      var timer = setInterval(function () {
        if (i < text.length) {
          typed!.textContent += text[i++];
        } else {
          clearInterval(timer);
          setTimeout(function () {
            cursor!.style.display = 'none';
            subLine!.style.opacity = '1';
          }, 180);
        }
      }, 55);
    }

    // Start immediately if there's no boot screen (e.g. navigated page, cached load)
    if (!document.getElementById('boot-screen')) {
      startTyping();
    } else {
      window.addEventListener('boot-complete', startTyping, { once: true });
    }
  })();
</script>
