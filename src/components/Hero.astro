---
// Hero
---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden px-5 pt-20">

  <!-- Background gradients -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--color-brand-primary)_0%,_transparent_50%)] opacity-15"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,_var(--color-brand-accent)_0%,_transparent_40%)] opacity-10"></div>

  <!-- Dot grid -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 32px 32px;"></div>

  <!-- Floating orbs -->
  <div class="pointer-events-none absolute" style="left:11%;top:20%;width:320px;height:320px;border-radius:50%;background:radial-gradient(circle,rgba(22,180,210,0.13),transparent 70%);filter:blur(55px);animation:float-orb 11s ease-in-out infinite;will-change:transform;"></div>
  <div class="pointer-events-none absolute" style="right:9%;top:35%;width:260px;height:260px;border-radius:50%;background:radial-gradient(circle,rgba(86,129,208,0.16),transparent 70%);filter:blur(55px);animation:float-orb 14s ease-in-out infinite 3.5s;will-change:transform;"></div>
  <div class="pointer-events-none absolute hidden md:block" style="left:42%;bottom:16%;width:200px;height:200px;border-radius:50%;background:radial-gradient(circle,rgba(22,180,210,0.09),transparent 70%);filter:blur(45px);animation:float-orb 9s ease-in-out infinite 1.8s;will-change:transform;"></div>

  <div id="hero-content" class="relative z-10 mx-auto max-w-3xl text-center">

    <!-- Badge -->
    <div class="hero-el mb-6 inline-block rounded-full border border-border-subtle bg-bg-card px-4 py-1.5 text-sm text-text-secondary backdrop-blur-sm" style="--i:0">
      Developer &middot; Consultant &middot; Builder
    </div>

    <!-- Headline -->
    <h1 class="hero-el hero-glow text-4xl font-bold leading-tight tracking-tight md:text-5xl lg:text-6xl" style="--i:1">
      We Build Technology<br />
      <span class="bg-linear-to-r from-brand-primary to-brand-accent bg-clip-text text-transparent">
        for Small Businesses.
      </span>
    </h1>

    <!-- Body -->
    <p class="hero-el mx-auto mt-6 max-w-xl text-lg leading-relaxed text-text-secondary md:text-xl" style="--i:2">
      Available now for tech consulting, web design, and custom software —
      serving small businesses in Tampa, FL and remotely.
      Also building <strong class="font-semibold text-text-primary">Trackt</strong> — real-time inventory
      tracking and sales analytics for small business owners, launching soon.
    </p>

    <!-- CTAs -->
    <div class="hero-el mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center" style="--i:3">
      <a
        href="/#consulting"
        class="btn-shimmer inline-flex w-full items-center justify-center gap-2 rounded-xl bg-brand-primary px-8 py-4 text-lg font-semibold text-white transition-all hover:brightness-110 hover:shadow-[0_0_30px_var(--color-brand-glow)] sm:w-auto"
      >
        Let's Work Together
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a
        href="#waitlist"
        class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-brand-primary/50 px-8 py-4 text-lg font-semibold text-brand-primary transition-all hover:bg-brand-primary/10 sm:w-auto"
      >
        Follow Trackt
      </a>
    </div>

  </div>
</section>

<style>
  .hero-el {
    opacity: 0;
  }

  #hero-content.is-visible .hero-el {
    animation: fade-up 0.65s cubic-bezier(0.16, 1, 0.3, 1) calc(var(--i, 0) * 0.18s) both;
  }

  /* Headline gets glow layered on top of fade-up */
  #hero-content.is-visible .hero-glow {
    animation:
      fade-up 0.65s cubic-bezier(0.16, 1, 0.3, 1) calc(var(--i, 0) * 0.18s) both,
      glow-settle 2.2s ease-out calc(var(--i, 0) * 0.18s) both;
  }
</style>

<script>
  const content = document.getElementById('hero-content');
  if (content) {
    const show = () => content.classList.add('is-visible');
    if (!document.getElementById('boot-screen')) {
      show();
    } else {
      window.addEventListener('boot-complete', show, { once: true });
    }
  }
</script>
